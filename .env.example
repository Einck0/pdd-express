# .env template
PDD_APP_VERSION=1.1
PDD_APP_HOST=0.0.0.0
PDD_APP_PORT=5000
PDD_APP_DEBUG=false

PDD_API_PREFIX=/express

PDD_WECHAT_APPID=
PDD_WECHAT_SECRET=

# Database backend selection:
# - auto: use MySQL when mysql host/user/database are present, otherwise SQLite
# - sqlite: always use SQLite
# - mysql: always use MySQL
PDD_DB_BACKEND=auto

# SQLite settings
PDD_SQLITE_DATABASE_DIR=./
PDD_SQLITE_DATABASE_NAME=pdd.db

# MySQL settings
PDD_MYSQL_HOST=
PDD_MYSQL_PORT=3306
PDD_MYSQL_USER=
PDD_MYSQL_PASSWORD=
PDD_MYSQL_DATABASE=

PDD_MOBILE=
PDD_ENCRYPTED_PASSWORD=
PDD_COOKIE_STRING=
PDD_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36 Edg/135.0.0.0
